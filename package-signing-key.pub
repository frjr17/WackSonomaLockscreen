<style>
.authorized-access{
display:none;
}
.fdn-zdcm-customer-stories__side-content__point h3:empty {display: none;}
/** Alert Banner **/
.hero--hub-hero-homepage.hero--simple-text .hero__content:has(.fdn-alert-banner) {padding-top: 0;}
.hero__content:has(.fdn-alert-banner.fdn-alert-banner--homepage-v2[style*="display: none"]) {
  padding-top: 40px;
}
.fdn-alert-banner.fdn-alert-banner--homepage-v2 {position: unset;margin-bottom: 20px;}
@media (min-width: 768px) {
.fdn-alert-banner.fdn-alert-banner--homepage-v2 {margin-bottom: 40px;}
    .hero--hub-hero-homepage.hero--simple-text .hero__content:has(.fdn-alert-banner) {
        padding-top: 0;
    }
.hero__content:has(.fdn-alert-banner.fdn-alert-banner--homepage-v2[style*="display: none"]) {
  padding-top: 40px;
}
}
@media (min-width: 1024px) {
.hero__content:has(.fdn-alert-banner.fdn-alert-banner--homepage-v2[style*="display: none"]) {
  padding-top: 60px;
}
.fdn-alert-banner.fdn-alert-banner--homepage-v2 {margin-bottom: 60px;}
}
/** Alert Banner **/
/** QA feedbacks **/
@media(max-width: 1024px) {
.fdn-zdcm-customer-stories__grid .grid-column .grid-card img {filter: invert(1) brightness(100%) contrast(100%);}
.fdn-zdcm-customer-stories__grid .grid-column .grid-card img {height: 40px;}
}
.hero .custom-swiper-slider {
    margin-top: 20px;
}
@media(min-width: 768px) {
    .hero .custom-swiper-slider {
        margin-top: 40px;
    }
}
@media(min-width: 768px) {
    .hero .custom-swiper-slider {
        margin-top: 60px;
    }
}
.fdn-alert-banner--homepage-v2 .fdn-alert-banner__link {
    background: linear-gradient(-81.05deg, rgba(251, 50, 126, 1.00) 0%, rgba(11, 92, 255, 1.00) 100%);
    padding: 7.27px 14px 7.27px 14px;
    border-radius: 10px;
    text-decoration: none;
    line-height: 16.8px;
}
@media (max-width: 768px) {
    .fdn-zdcm-feature-accordion.zdcm-module-column-reverse .fdn-zdcm-feature-accordion__accordion-item .fdn-zdcm-feature-accordion__accordion-content {
        flex-direction: column-reverse;
    }
}
.fdn-alert-banner--homepage-v2 .fdn-alert-banner__text {font-size: 16px; line-height: 26.1px;}
.fdn-alert-banner--homepage-v2 .fdn-alert-banner__link {font-size: 16px;}
html:lang(ja) .zdcm-header-v1.zdcm-global-navigation .zdcm-main-nav__megamenu-trigger+.zdcm-megamenu .zdcm-megamenu-products-shadow {top: 67px;}
/** QA feedbacks **/
@media (max-height: 560px) {
        .zdcm-header-v1 .zdcm-mobile-menu .zdcm-accordion-content[aria-hidden=false] .zdcm-megamenu.zdcm-megamenu-ai .zdcm-megamenu-products-categories>.zdcm-column-1>.zdcm-megamenu__column--block {
            height: calc(100dvh - 120px);
            overflow-y: auto;
        }
    }
@media(min-width: 1025px){
html[lang="fr"] .hero--hub-hero-homepage.hero--simple-text .hero__body-text, html[lang="pl"] .hero--hub-hero-homepage.hero--simple-text .hero__body-text, html[lang="ru"] .hero--hub-hero-homepage.hero--simple-text .hero__body-text, html[lang="tr"] .hero--hub-hero-homepage.hero--simple-text .hero__body-text, html[lang="de"] .hero--hub-hero-homepage.hero--simple-text .hero__body-text {
max-width: 1000px; margin: 0px auto;}
}
@media (max-width: 767px) {
#announcement-card .fdn-zdcm-cards.zdcm-fdn-announcement-card {
padding: 1.5rem 1.5rem 0;}
#announcement-card .custom-swiper-slider__slide-content img {
max-width: 200px;}#announcement-card .fdn-zdcm-cards.zdcm-fdn-announcement-card p:last-child {margin-bottom: 0;}
#three-tiles .custom-swiper-slider__navigation-wrapper .custom-swiper-slider__button {
display: inline-flex !important;
}
}

