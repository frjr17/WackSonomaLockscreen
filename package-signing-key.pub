        <script>window.zoomCampaignSdkConfig={getAuthCredentials:function(){const cookies=document.cookie;const cookieArray=cookies.split('; ');const cookieMap={};cookieArray.forEach(cookie=>{const[key,value]=cookie.split('=');cookieMap[decodeURIComponent(key)]=decodeURIComponent(value);});const guid=cookieMap['_zm_cms_guid']||'';return fetch('https://zoom.us/zendesk/chat_jwt_asym?cms_guid='+guid,{credentials:'include'}).then(res=>res.json().then(data=>({data:data,traceId:res.headers.get('x-zm-trackingid')}))).then(({data,traceId})=>({jwt:data?.loginUserIdJwt,traceId:traceId}));}};</script><script type='text/javascript' src='https://us01ccistatic.zoom.us/us01cci/web-sdk/chat-client.js' defer="" data-lazy-load-campaign-url='_blank' data-apikey='AM_FKF55QOG_vdWum455Vg'></script>
