            <input type="hidden" id="coveo-search-api" value="https://www.zoom.com/api/coveo-search/">
                <div id="coveo-fetched-scripts">
<script>
window.__zoomCoveoConfig = {
  userLocale: 'en-us',
  apiKey: 'xxf1623479-48a6-4dce-8475-28e0b0720fbc',
  coreScriptSrc: 'https://st1.zoom.us/homepage/20260622-1234/primary/dist/ClientResources/Scripts/CoveoLazyLoad/CoveoJsSearch.Lazy.min.js?',
  langScriptSrc: 'https://st1.zoom.us/homepage/20260622-1234/primary/dist/ClientResources/Scripts/coveo-en.js?',
  searchUrl: 'https://www.zoom.com/en/search/',
  placeholder: 'Enter search here...',
  enableFocusBehavior: false,
  localeStrings: {
                "en-us": {
                    "Search": "Search",
                    "ZoomPlaceholder": "Enter search here...",
                    "ZoomHeader": "What are you looking for?",
                    "All": "All",
                    "Support": "Support",
                    "Videos": "Videos",
                    "Source": "Source",
                    "Explore Zoom": "Explore Zoom",
                    "Solutions": "Solutions",
                    "Support Articles": "Support Articles",
                    "Community": "Community",
                    "InsertAQuery": "Insert a query",
                    "PressEnterToSend": "Press enter to send",
                }
            }
};
</script>
<script>
(function() {
  var injected = false;
  var coveoReady = false;
  var searchTriggered = false;
  var desktopMinWidth = 1200;

  function shouldAutoFocus() {
    return window.matchMedia('(min-width: ' + desktopMinWidth + 'px)').matches;
  }

  function focusCoveoInput(root) {
    var attempts = 0;
    var focusInterval = setInterval(function() {
      var searchInput =
        root.querySelector('.magic-box-input input') ||
        root.querySelector('.magic-box-input textarea') ||
        root.querySelector('.CoveoSearchbox input') ||
        root.querySelector('.CoveoSearchbox textarea') ||
        root.querySelector('.CoveoOmnibox input');

      if (searchInput) {
        searchInput.focus();
        clearInterval(focusInterval);
      } else if (++attempts >= 20) {
        clearInterval(focusInterval);
      }
    }, 100);
  }

  function revealAndFocusSearch() {
    ['#standaloneSearchbox', '#standaloneSearchboxMobile'].forEach(function(sel) {
      var root = document.querySelector(sel);
      if (!root) return;

      var searchBox = root.querySelector('.CoveoSearchbox');
      var flyoutBtn = root.querySelector('.FlyoutButton');

      if (searchBox && searchBox.classList.contains('transition-hidden')) {
        searchBox.classList.remove('transition-hidden');
      }

      if (flyoutBtn && !flyoutBtn.classList.contains('transition-hidden')) {
        flyoutBtn.classList.add('transition-hidden');
      }

      focusCoveoInput(root);
    });
  }

  function injectSearchScript() {
    if (injected) return;
    injected = true;

    var config = window.__zoomCoveoConfig;
    var scriptContainer = document.getElementById('coveo-fetched-scripts');
    if (!scriptContainer || !config) return;

    var coreScript = document.createElement('script');
    coreScript.src = config.coreScriptSrc;
    coreScript.async = true;

    coreScript.onload = function() {
      var langScript = document.createElement('script');
      langScript.src = config.langScriptSrc;
      langScript.async = true;

      langScript.onload = function() {
        var userLocale = String(config.userLocale || '').toLowerCase();
        var apiKey = config.apiKey;

        if (window.Globalize && Globalize.cultures) {
          var localeKey = userLocale.toUpperCase();
          var fallbackUpper = userLocale.split('-')[0].toUpperCase();
          var localeCulture = Globalize.cultures[localeKey] || Globalize.cultures[fallbackUpper];
          if (localeCulture && localeCulture.calendar && localeCulture.calendar.patterns) {
            localeCulture.calendar.patterns.d = config.datePattern || (userLocale.indexOf('ko') === 0 ? 'yyyy/MM/dd' : 'dd/MM/yyyy');
          }
        }

        if (config.localeStrings) {
          String.toLocaleString(config.localeStrings);
        }
        String.locale = userLocale;

        var localizedStrings = config.localeStrings || {};
        var localeBundle = localizedStrings[userLocale] || localizedStrings[userLocale.split('-')[0]] || {};
        var searchButtonText = localeBundle.Search || 'Search';
        document.querySelectorAll('#nav-coveo-search-btn').forEach(function(buttonEl) {
          buttonEl.textContent = searchButtonText;
          buttonEl.setAttribute('aria-label', searchButtonText);
        });

        Coveo.SearchEndpoint.configureCloudV2Endpoint('', apiKey, 'https://platform.cloud.coveo.com/rest/search');

        function initSearchbox(rootSelector) {
          var root = document.querySelector(rootSelector);
          if (!root) return;

          Coveo.initSearchbox(root, config.searchUrl, {
            Analytics: { searchHub: 'Marketing' },
            Searchbox: { placeholder: config.placeholder }
          });

          Coveo.$$(root).on(Coveo.InitializationEvents.afterComponentsInitialization, function() {
            var clearBtn = root.querySelector('.magic-box-clear');
            if (clearBtn) {
              clearBtn.addEventListener('click', function() {
                var searchbox = root.querySelector('.CoveoSearchbox');
                var flyout = root.querySelector('.FlyoutButton');
                if (searchbox) searchbox.classList.toggle('transition-hidden');
                if (flyout) flyout.classList.toggle('transition-hidden');
              });
            }

            var button = document.querySelector("[data-searchcoveo-button='true']");
            if (button && getComputedStyle(button).display === 'none') {
              button.removeAttribute('style');
            }

            coveoReady = true;
            if (config.enableFocusBehavior && searchTriggered && shouldAutoFocus()) {
              revealAndFocusSearch();
            }
          });

          var flyoutButton = root.querySelector('.FlyoutButton');
          if (flyoutButton) {
            flyoutButton.addEventListener('click', function() {
              var searchbox = root.querySelector('.CoveoSearchbox');
              var flyout = root.querySelector('.FlyoutButton');
              if (searchbox) searchbox.classList.toggle('transition-hidden');
              if (flyout) flyout.classList.toggle('transition-hidden');
              if (config.enableFocusBehavior && shouldAutoFocus()) {
                focusCoveoInput(root);
              }
            });
          }
        }

        initSearchbox('#standaloneSearchbox');
        initSearchbox('#standaloneSearchboxMobile');
      };

      scriptContainer.appendChild(langScript);
    };

    scriptContainer.appendChild(coreScript);
  }

  var triggers = [
    document.getElementById('nav-search-trigger-desktop'),
    document.querySelector('.nav-header__hamburger')
  ];

  triggers.forEach(function(el) {
    if (el) {
      el.addEventListener('click', function() {
        searchTriggered = el && el.id === 'nav-search-trigger-desktop';
        injectSearchScript();
      }, { once: true });
    }
  });

  var searchBtn = document.getElementById('nav-search-trigger-desktop');
  if (searchBtn) {
    searchBtn.addEventListener('click', function() {
      searchTriggered = true;
      if (coveoReady && window.__zoomCoveoConfig && window.__zoomCoveoConfig.enableFocusBehavior && shouldAutoFocus()) {
        setTimeout(revealAndFocusSearch, 50);
      }
    });
  }
})();
</script>
</div>
    </div>
