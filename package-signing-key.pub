<script nonce="eewcjHGE0v3KnfHV0wnKtyMwzXzC49IAPBl+i9CPLL8=">
window.addEventListener('load', () => {
document.querySelectorAll('.fdn-zdcm-customer-stories__side-content__point  h3:empty').forEach(el => el.remove());
document.querySelectorAll('main#main img').forEach(img => {
  let srcset = img.getAttribute('srcset');
  if (srcset) {
    // Remove the " 2x" part (leading space and the 2x)
    let cleanedSrcset = srcset.replace(/\s*\d+x$/, '');
    img.setAttribute('srcset', cleanedSrcset);
  }
});
});
</script>
<style>
