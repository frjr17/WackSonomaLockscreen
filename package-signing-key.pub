                <div class="column column-1">
                    <div class="swiper zdcm-cs-expanded-card__swiper zdcm-cs-expanded-card__wrapper zdcm-navigation-arrows-disabled" data-cmp-is="zdcm-customer-stories-expanded-card">
                        <div class="swiper-wrapper zdcm-cs-expanded-card__swiper-wrapper zdcm-cs-expanded-card__wrapper-inner">
                                <div class="swiper-slide zdcm-cs-expanded-card__swiper-slide greyscale-collapsed swiper-slide-visible swiper-slide-active expanded" data-image-position="">
        <a href="https://www.zoom.com/en/customer-stories/major-league-baseball/" class="anchor-link js-analytics-cta" title="Read more" data-title="" data-link-type="" data-en-text="">Read more<span class="visually-hidden"> Read more</span></a>
                                    <img class="zdcm-cs-expanded-card__background-image" alt="Major League Baseball" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/baseball-club-bg-n.jpg">
                                    <div class="zdcm-cs-expanded-card__content">
                                        <img class="zdcm-cs-expanded-card__logo" alt="Major League Baseball" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-4.svg" alt="Major League Baseball&#x2122; and Zoom expand the employee-fan experience">
                                        <h3 class="zdcm-cs-expanded-card__content__heading animated">Major League Baseball&#x2122; and Zoom expand the employee-fan experience</h3>
                                        <div class="zdcm-cs-expanded-card__content__stats animated">
                                                <div class="stat-wrapper">
                                                    <div class="metric-value"></div>
                                                    <div class="text-label"><p>"Zoom has allowed us to continue a tradition of really being a technology-focused company and making sure that we are using cutting-edge technology not only to advance our business but also for our fans."<br><br></p>
<p>- <strong>Noah Garden</strong>, Chief Revenue Officer</p></div>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="swiper-slide zdcm-cs-expanded-card__swiper-slide greyscale-collapsed collapsed" data-image-position="80%">
        <a href="https://www.zoom.com/en/customer-stories/theshareco/" class="anchor-link js-analytics-cta" title="Read more" data-title="" data-link-type="" data-en-text="">Read more<span class="visually-hidden"> Read more</span></a>
                                    <img class="zdcm-cs-expanded-card__background-image" alt="TheShareCo Background" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/share-bg.jpg">
                                    <div class="zdcm-cs-expanded-card__content">
                                        <img class="zdcm-cs-expanded-card__logo" alt="TheShareCo" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-mlb-white.svg" alt="Advancing mental wellness through TheShareCo&#x2019;s journey with Zoom Video SDK">
                                        <h3 class="zdcm-cs-expanded-card__content__heading animated">Advancing mental wellness through TheShareCo&#x2019;s journey with Zoom Video SDK</h3>
                                        <div class="zdcm-cs-expanded-card__content__stats animated">
                                                <div class="stat-wrapper">
                                                    <div class="metric-value"></div>
                                                    <div class="text-label"><p>"Zoom Video SDKs full flexibility in layout customization allowed us to achieve a real-life experience within the limited real estate presented by a phone or smart device."<br><br></p>
<p>- <strong>Tan Han Sing</strong>, Founder and CEO, TheShareCo</p></div>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="swiper-slide zdcm-cs-expanded-card__swiper-slide greyscale-collapsed collapsed" data-image-position="65%">
        <a href="https://www.zoom.com/en/customer-stories/cricut/" class="anchor-link js-analytics-cta" title="Read more" data-title="" data-link-type="" data-en-text="">Read more<span class="visually-hidden"> Read more</span></a>
                                    <img class="zdcm-cs-expanded-card__background-image" alt="Cricut" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/cricut-bg.jpg">
                                    <div class="zdcm-cs-expanded-card__content">
                                        <img class="zdcm-cs-expanded-card__logo" alt="Cricut" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-2.svg" alt="Cricut slashed call abandonment rates by 90% with Zoom">
                                        <h3 class="zdcm-cs-expanded-card__content__heading animated">Cricut slashed call abandonment rates by 90% with Zoom</h3>
                                        <div class="zdcm-cs-expanded-card__content__stats animated">
                                                <div class="stat-wrapper">
                                                    <div class="metric-value"></div>
                                                    <div class="text-label"><p>"Before Zoom, we juggled 10-plus tabs to handle calls. Now, everything is integrated into one clean platform, from CRM connections to video transitions. It is a dream workflow."<br><br></p>
<p>- <strong>Taylor Nelson</strong>, Member Care QA Specialist</p></div>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="swiper-slide zdcm-cs-expanded-card__swiper-slide greyscale-collapsed collapsed" data-image-position="">
        <a href="https://www.zoom.com/en/customer-stories/capital-one/" class="anchor-link js-analytics-cta" title="Read more" data-title="" data-link-type="" data-en-text="">Read more<span class="visually-hidden"> Read more</span></a>
                                    <img class="zdcm-cs-expanded-card__background-image" alt="Capital One" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/capital-one-bg.jpg">
                                    <div class="zdcm-cs-expanded-card__content">
                                        <img class="zdcm-cs-expanded-card__logo" alt="Capital One" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-3.svg" alt="A connected, collaborative workforce drives innovation at Capital One">
                                        <h3 class="zdcm-cs-expanded-card__content__heading animated">A connected, collaborative workforce drives innovation at Capital One</h3>
                                        <div class="zdcm-cs-expanded-card__content__stats animated">
                                                <div class="stat-wrapper">
                                                    <div class="metric-value"></div>
                                                    <div class="text-label"><p>"We are highly collaborative, we are people-centered, we are interested in moving ourselves and our goals to the next level. Zoom is, I believe, the ideal tool to suit the culture that we are and that we strive to be at Capital One."<br><br></p>
<p>- <strong>Nikita Steals</strong>, VP, Tech Talent Acquisition, Capital One</p></div>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                        </div>
                    </div>
                    <div class="fdn-zdcm-customer-stories__container" data-cmp-is="fdn-zdcm-customer-stories">
                        <div class="fdn-zdcm-customer-stories__grid">
                            <div class="grid-column">
                                    <div class="grid-card grid-card--selected" data-id="major-league-baseball&#x2122;-and-zoom-expand-the-employee-fan-experience" data-title="Major League Baseball&#x2122; and Zoom expand the employee-fan experience" data-stats="[{&quot;title&quot;:&quot;&quot;,&quot;desc&quot;:&quot;&lt;p&gt;\&quot;Zoom has allowed us to continue a tradition of really being a technology-focused company and making sure that we are using cutting-edge technology not only to advance our business but also for our fans.\&quot;&lt;br /&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p&gt;- &lt;strong&gt;Noah Garden&lt;/strong&gt;, Chief Revenue Officer&lt;/p&gt;&quot;}]" data-bg="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/baseball-club-bg-n.jpg" data-cta='Read more' data-link='https://www.zoom.com/en/customer-stories/major-league-baseball/'>
                                        <img alt="Major League Baseball" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-4.svg" https:="" www.zoom.com="">
                                    </div>
                                    <div class="grid-card grid-card--outline" data-id="advancing-mental-wellness-through-theshareco&#x2019;s-journey-with-zoom-video-sdk" data-title="Advancing mental wellness through TheShareCo&#x2019;s journey with Zoom Video SDK" data-stats="[{&quot;title&quot;:&quot;&quot;,&quot;desc&quot;:&quot;&lt;p&gt;\&quot;Zoom Video SDKs full flexibility in layout customization allowed us to achieve a real-life experience within the limited real estate presented by a phone or smart device.\&quot;&lt;br /&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p&gt;- &lt;strong&gt;Tan Han Sing&lt;/strong&gt;, Founder and CEO, TheShareCo&lt;/p&gt;&quot;}]" data-bg="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/share-bg.jpg" data-cta='Read more' data-link='https://www.zoom.com/en/customer-stories/theshareco/'>
                                        <img alt="TheShareCo Background" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-mlb-white.svg" https:="" www.zoom.com="">
                                    </div>
                                    <div class="grid-card grid-card--outline" data-id="cricut-slashed-call-abandonment-rates-by-90%-with-zoom" data-title="Cricut slashed call abandonment rates by 90% with Zoom" data-stats="[{&quot;title&quot;:&quot;&quot;,&quot;desc&quot;:&quot;&lt;p&gt;\&quot;Before Zoom, we juggled 10-plus tabs to handle calls. Now, everything is integrated into one clean platform, from CRM connections to video transitions. It is a dream workflow.\&quot;&lt;br /&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p&gt;- &lt;strong&gt;Taylor Nelson&lt;/strong&gt;, Member Care QA Specialist&lt;/p&gt;&quot;}]" data-bg="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/cricut-bg.jpg" data-cta='Read more' data-link='https://www.zoom.com/en/customer-stories/cricut/'>
                                        <img alt="Cricut" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-2.svg" https:="" www.zoom.com="">
                                    </div>
                                    <div class="grid-card grid-card--outline" data-id="a-connected,-collaborative-workforce-drives-innovation-at-capital-one" data-title="A connected, collaborative workforce drives innovation at Capital One" data-stats="[{&quot;title&quot;:&quot;&quot;,&quot;desc&quot;:&quot;&lt;p&gt;\&quot;We are highly collaborative, we are people-centered, we are interested in moving ourselves and our goals to the next level. Zoom is, I believe, the ideal tool to suit the culture that we are and that we strive to be at Capital One.\&quot;&lt;br /&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p&gt;- &lt;strong&gt;Nikita Steals&lt;/strong&gt;, VP, Tech Talent Acquisition, Capital One&lt;/p&gt;&quot;}]" data-bg="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/capital-one-bg.jpg" data-cta='Read more' data-link='https://www.zoom.com/en/customer-stories/capital-one/'>
                                        <img alt="Capital One" src="https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/logo-3.svg" https:="" www.zoom.com="">
                                    </div>
                            </div>
                        </div>
                            <div class="fdn-zdcm-customer-stories__content">
                                <div class="fdn-zdcm-customer-stories__story" style="--dynamic-bg: url('https://st1.zoom.us/homepage/20260622-1234/primary/dist/assets/zoommedia/baseball-club-bg-n.jpg');">
                                    <div class="fdn-zdcm-customer-stories__story-content">
