                          <script type="text/javascript" nonce="eewcjHGE0v3KnfHV0wnKtyMwzXzC49IAPBl+i9CPLL8=">
                            (function updatePhoneByMarket() {
                                var defaultPhoneDisplay = '+1.888.799.9666';
                                var defaultPhoneHref = 'tel:+18887999666';
                                var marketPhones = {
                                    US: {
                                        display: '+1.888.303.1012',
                                        href: '+18883031012'
                                    },
                                    GB: {
                                        display: '+44 800 066 8806',
                                        href: '+448000668806'
                                    },
                                    UK: {
                                        display: '+44 800 066 8806',
                                        href: '+448000668806'
                                    },
                                    SG: {
                                        display: '+65 6460 2744',
                                        href: '+6564602744'
                                    }
                                };

                                function copyLinkAttributes(source, target) {
                                    for (var i = 0; i < source.attributes.length; i += 1) {
                                        var attr = source.attributes[i];
                                        if (!attr || !attr.name || attr.name === 'href' || attr.name.indexOf('data-market-phone-') === 0) {
                                            continue;
                                        }
                                        target.setAttribute(attr.name, attr.value);
                                    }
                                }

                                function createPhoneLink(templateLink, href, text) {
                                    var link = document.createElement('a');
                                    copyLinkAttributes(templateLink, link);
                                    link.setAttribute('href', href);
                                    link.setAttribute('data-market-phone-managed', 'true');
                                    link.textContent = text;
                                    return link;
                                }

                                function shouldStackNumbersForLink(link) {
                                    var isTabletViewport = window.matchMedia('(min-width: 768px) and (max-width: 1024px)').matches;
                                    var isFooterLogoDescLink = Boolean(link.closest('.zdcm-module-footer-nav__logo-desc'));
                                    return Boolean(
                                        link.closest('.nav-sidebar__footer')
                                        || (link.closest('.zdcm-module-footer') && (!isFooterLogoDescLink || !isTabletViewport))
                                    );
                                }

                                function shouldTightenSlashSpacingForLink(link, shouldStackNumbers) {
                                    return Boolean(!shouldStackNumbers && link.closest('.nav-drawer, .nav-footer'));
                                }

                                function shouldUseSalesFooterGap(link) {
                                    var section = link.closest('.zdcm-module-footer-nav__section');
                                    if (!section) {
                                        return false;
                                    }

                                    var sectionTitle = section.querySelector('.zdcm-module-footer-nav__title');
                                    if (!sectionTitle) {
                                        return false;
                                    }

                                    var sectionTitleText = (sectionTitle.textContent || '').replace(/\s+/g, ' ').trim().toLowerCase();
                                    var sectionTitleHref = (sectionTitle.getAttribute('href') || '').toLowerCase();
                                    return sectionTitleText === 'sales' || sectionTitleHref.indexOf('/contact/contact-sales/') !== -1;
                                }

                                function applyMarketGroupLayout(group, shouldStackNumbers, shouldTightenSlashSpacing, useSalesFooterGap) {
                                    var links = group.querySelectorAll('a[data-market-phone-managed="true"]');
                                    if (links.length < 2) {
                                        return;
                                    }

                                    group.style.display = '';
                                    group.style.flexDirection = '';
                                    group.style.alignItems = '';
                                    group.style.gap = '';
                                    links[0].style.display = '';
                                    links[1].style.display = '';
                                    links[0].style.paddingRight = '';
                                    links[1].style.paddingLeft = '';

                                    var separator = group.querySelector('span[data-market-phone-separator="true"]');
                                    if (separator) {
                                        separator.remove();
                                    }

                                    if (shouldStackNumbers) {
                                        group.style.display = 'inline-flex';
                                        group.style.flexDirection = 'column';
                                        group.style.alignItems = 'flex-start';
                                        group.style.gap = useSalesFooterGap ? '16px' : '6px';
                                        links[0].style.display = 'block';
                                        links[1].style.display = 'block';
                                        return;
                                    }

                                    if (shouldTightenSlashSpacing) {
                                        links[0].style.paddingRight = '0';
                                        links[1].style.paddingLeft = '0';
                                    }

                                    separator = document.createElement('span');
                                    separator.setAttribute('data-market-phone-separator', 'true');
                                    separator.textContent = ' / ';
                                    links[0].after(separator);
                                }

                                function splitLinkIntoMarketGroup(link, marketPhone) {
                                    var wrapper = document.createElement('span');
                                    wrapper.setAttribute('data-market-phone-group', 'true');
                                    var defaultLink = createPhoneLink(link, defaultPhoneHref, defaultPhoneDisplay);
                                    var marketLink = createPhoneLink(link, 'tel:' + marketPhone.href, marketPhone.display);
                                    var shouldStackNumbers = shouldStackNumbersForLink(link);

                                    wrapper.appendChild(defaultLink);
                                    wrapper.appendChild(marketLink);
                                    applyMarketGroupLayout(
                                        wrapper,
                                        shouldStackNumbers,
                                        shouldTightenSlashSpacingForLink(link, shouldStackNumbers),
                                        shouldUseSalesFooterGap(link)
                                    );

                                    link.replaceWith(wrapper);
                                }

                                function mergeMarketGroupToDefault(group) {
                                    var links = group.querySelectorAll('a[data-market-phone-managed="true"]');
                                    if (!links.length) {
                                        return;
                                    }

                                    var defaultLink = links[0].cloneNode(true);
                                    defaultLink.setAttribute('href', defaultPhoneHref);
                                    defaultLink.textContent = defaultPhoneDisplay;
                                    group.replaceWith(defaultLink);
                                }

                                function updateMarketGroups(marketPhone) {
                                    var groups = document.querySelectorAll('span[data-market-phone-group="true"]');
                                    groups.forEach(function (group) {
                                        if (!marketPhone) {
                                            mergeMarketGroupToDefault(group);
                                            return;
                                        }

                                        var links = group.querySelectorAll('a[data-market-phone-managed="true"]');
                                        if (links.length >= 2) {
                                            links[0].setAttribute('href', defaultPhoneHref);
                                            links[0].textContent = defaultPhoneDisplay;
                                            links[1].setAttribute('href', 'tel:' + marketPhone.href);
                                            links[1].textContent = marketPhone.display;
                                            var groupAnchor = links[0];
                                            var shouldStackNumbers = shouldStackNumbersForLink(groupAnchor);
                                            applyMarketGroupLayout(
                                                group,
                                                shouldStackNumbers,
                                                shouldTightenSlashSpacingForLink(groupAnchor, shouldStackNumbers),
                                                shouldUseSalesFooterGap(groupAnchor)
                                            );
                                        }
                                    });
                                }

                                function normalizePhoneValue(value) {
                                    return (value || '').toString().replace(/[^0-9]/g, '');
                                }

                                function updatePhoneLinks(countryCode) {
                                    var normalizedCountry = countryCode ? countryCode.toUpperCase() : '';
                                    var marketPhone = marketPhones[normalizedCountry];
                                    var defaultPhoneDigits = normalizePhoneValue(defaultPhoneHref);

                                    updateMarketGroups(marketPhone);

                                    var phoneLinks = document.querySelectorAll('a[href^="tel:"], a[data-market-phone-managed="true"]');

                                    phoneLinks.forEach(function (link) {
                                        if (link.closest('span[data-market-phone-group="true"]')) {
                                            return;
                                        }

                                        var linkText = (link.textContent || '').replace(/\s+/g, ' ').trim();
                                        var isManaged = link.getAttribute('data-market-phone-managed') === 'true';
                                        var hrefPhoneDigits = normalizePhoneValue(link.getAttribute('href'));
                                        var textPhoneDigits = normalizePhoneValue(linkText);
                                        var enTextPhoneDigits = normalizePhoneValue(link.getAttribute('data-en-text'));
                                        var hasPhoneDisplay = linkText.indexOf(defaultPhoneDisplay) !== -1
                                            || hrefPhoneDigits === defaultPhoneDigits
                                            || textPhoneDigits === defaultPhoneDigits
                                            || enTextPhoneDigits === defaultPhoneDigits;

                                        if (!isManaged && !hasPhoneDisplay) {
                                            return;
                                        }

                                        if (!marketPhone) {
                                            link.setAttribute('href', defaultPhoneHref);
                                            link.setAttribute('data-market-phone-managed', 'true');
                                            if (link.dataset && Object.prototype.hasOwnProperty.call(link.dataset, 'enText')) {
                                                link.dataset.enText = defaultPhoneDisplay;
                                            }
                                            return;
                                        }

                                        splitLinkIntoMarketGroup(link, marketPhone);
                                    });
                                }

                                function getCountryFromMarketVerify(event) {
                                    var body = event && event.detail && event.detail.body ? event.detail.body : {};
                                    return (body.countryCode || body.countrycode || body.userCountry || body.usercountry || body.billingCountry || '').toString();
                                }

                                var activeCountryCode = '';
                                var resizeTimer;

                                function refreshPhoneLinksForViewport() {
                                    updatePhoneLinks(activeCountryCode);
                                }

                                updatePhoneLinks(activeCountryCode);

                                document.addEventListener('marketVerifyResponse', function (event) {
                                    activeCountryCode = getCountryFromMarketVerify(event);
                                    updatePhoneLinks(activeCountryCode);
                                });

                                window.addEventListener('resize', function () {
                                    clearTimeout(resizeTimer);
                                    resizeTimer = setTimeout(refreshPhoneLinksForViewport, 120);
                                });
                            })();
                        </script>
    

<script>(function(){function c(){var b=a.contentDocument||a.contentWindow.document;if(b){var d=b.createElement('script');d.innerHTML="window.__CF$cv$params={r:'a11031aa2fc84aca',t:'MTc4MjM1MDg5MC4wMDAwMDA='};var a=document.createElement('script');a.nonce='';a.src='/cdn-cgi/challenge-platform/scripts/jsd/main.js';document.getElementsByTagName('head')[0].appendChild(a);";b.getElementsByTagName('head')[0].appendChild(d)}}if(document.body){var a=document.createElement('iframe');a.height=1;a.width=1;a.style.position='absolute';a.style.top=0;a.style.left=0;a.style.border='none';a.style.visibility='hidden';document.body.appendChild(a);if('loading'!==document.readyState)c();else if(window.addEventListener)document.addEventListener('DOMContentLoaded',c);else{var e=document.onreadystatechange||function(){};document.onreadystatechange=function(b){e(b);'loading'!==document.readyState&&(document.onreadystatechange=e,c())}}}})();</script></body>
